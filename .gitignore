# ============================================================
# CampusConnect .gitignore
# ============================================================

# --- SECURITY: Never commit these ---
backend/.env
app/.env

# --- Node.js ---
node_modules/
backend/node_modules/
app/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Build outputs ---
app/dist/
app/build/

# --- Uploaded files (user content, not source code) ---
backend/uploads/*
!backend/uploads/.gitkeep

# --- Environment files (keep examples, ignore actuals) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Keep .env.example files (they are safe templates)
!backend/.env.example
!app/.env.example

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Logs ---
logs/
*.log

# --- TypeScript ---
*.tsbuildinfo

# --- Misc ---
.cache/
.parcel-cache/
